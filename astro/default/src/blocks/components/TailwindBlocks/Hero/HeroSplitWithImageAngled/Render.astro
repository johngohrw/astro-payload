---
import type { BlockTypeOf } from "@/blocks/blockTypes";
import Component from "./Component.astro";

const { block } = Astro.props;
const blockProps: BlockTypeOf<"heroSplitWithImageAngled"> = block;
const { heading, description, primaryCtaLabel, primaryCtaHref, secondaryCtaLabel, secondaryCtaHref, heroImage } = blockProps;
const remappedProps = {
  heading: heading ?? undefined,
  description: description ?? undefined,
  primaryCtaLabel: primaryCtaLabel ?? undefined,
  primaryCtaHref: primaryCtaHref ?? undefined,
  secondaryCtaLabel: secondaryCtaLabel ?? undefined,
  secondaryCtaHref: secondaryCtaHref ?? undefined,
  heroImageSrc: typeof heroImage === "object" && heroImage !== null ? heroImage.url ?? undefined : undefined,
};
---
<Component {...remappedProps} />
