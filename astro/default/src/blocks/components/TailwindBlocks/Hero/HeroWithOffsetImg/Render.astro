---
import type { BlockTypeOf } from "@/blocks/blockTypes";
import Component from "./Component.astro";

const { block } = Astro.props;
const blockProps: BlockTypeOf<"heroWithOffsetImg"> = block;
const { title, subtitle, buttonLabel, buttonHref, subActionLabel, subActionHref, images } = blockProps;
const remappedProps = {
  title: title ?? undefined,
  subtitle: subtitle ?? undefined,
  buttonLabel: buttonLabel ?? undefined,
  buttonHref: buttonHref ?? undefined,
  subActionLabel: subActionLabel ?? undefined,
  subActionHref: subActionHref ?? undefined,
  images: images?.map((item) =>
    typeof item.image === "object" && item.image !== null ? item.image.url ?? "" : ""
  ),
};
---
<Component {...remappedProps} />
