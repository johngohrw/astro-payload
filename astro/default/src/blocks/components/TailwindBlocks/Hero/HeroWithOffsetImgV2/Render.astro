---
import type { BlockTypeOf } from "@/blocks/blockTypes";
import Component from "./Component.astro";

const { block } = Astro.props;

const blockProps: BlockTypeOf<"heroWithOffsetImgV2"> = block;

const {
  logo,
  navLinks,
  login,
  heading,
  description,
  primaryCta,
  secondaryCta,
  galleryCol1Images,
  galleryCol2Images,
  galleryCol3Images,
} = blockProps;

const remappedProps = {
  logoSrc:
    typeof logo?.image === "object" && logo?.image !== null
      ? logo.image.url ?? undefined
      : undefined,
  logoDarkSrc:
    typeof logo?.darkImage === "object" && logo?.darkImage !== null
      ? logo.darkImage.url ?? undefined
      : undefined,
  logoAlt:
    typeof logo?.image === "object" && logo?.image !== null
      ? logo.image.alt ?? undefined
      : undefined,
  companyName: logo?.companyName ?? undefined,
  navLinks: navLinks?.map((link) => ({
    label: link.label ?? "",
    href: link.href ?? "#",
  })),
  loginLabel: login?.label ?? undefined,
  loginHref: login?.href ?? undefined,
  heading: heading ?? undefined,
  description: description ?? undefined,
  primaryCta: primaryCta
    ? { label: primaryCta.label ?? "", href: primaryCta.href ?? "#" }
    : undefined,
  secondaryCta: secondaryCta
    ? { label: secondaryCta.label ?? "", href: secondaryCta.href ?? "#" }
    : undefined,
  galleryCol1Images: galleryCol1Images?.map((item) => ({
    src:
      typeof item.image === "object" && item.image !== null
        ? item.image.url ?? undefined
        : undefined,
    alt:
      typeof item.image === "object" && item.image !== null
        ? item.image.alt ?? undefined
        : undefined,
  })),
  galleryCol2Images: galleryCol2Images?.map((item) => ({
    src:
      typeof item.image === "object" && item.image !== null
        ? item.image.url ?? undefined
        : undefined,
    alt:
      typeof item.image === "object" && item.image !== null
        ? item.image.alt ?? undefined
        : undefined,
  })),
  galleryCol3Images: galleryCol3Images?.map((item) => ({
    src:
      typeof item.image === "object" && item.image !== null
        ? item.image.url ?? undefined
        : undefined,
    alt:
      typeof item.image === "object" && item.image !== null
        ? item.image.alt ?? undefined
        : undefined,
  })),
};
---

<Component {...remappedProps} />
