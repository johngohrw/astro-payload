---
import type { BlockTypeOf } from "@/blocks/blockTypes";
import Component from "./Component.astro";

const { block } = Astro.props;
const blockProps: BlockTypeOf<"notFoundImageSplit"> = block;
const { companyName, logoLight, logoDark, logoHref, errorCode, heading, description, backLabel, backHref, footerLinks, backgroundImageLight, backgroundImageDark } = blockProps;
const remappedProps = {
  companyName: companyName ?? undefined,
  logoLightSrc: typeof logoLight === "object" && logoLight !== null ? logoLight.url ?? undefined : undefined,
  logoDarkSrc: typeof logoDark === "object" && logoDark !== null ? logoDark.url ?? undefined : undefined,
  logoHref: logoHref ?? undefined,
  errorCode: errorCode ?? undefined,
  heading: heading ?? undefined,
  description: description ?? undefined,
  backLabel: backLabel ?? undefined,
  backHref: backHref ?? undefined,
  footerLinks: footerLinks?.map((link) => ({
    label: link.label ?? undefined,
    href: link.href ?? undefined,
  })),
  backgroundImageLight: typeof backgroundImageLight === "object" && backgroundImageLight !== null ? backgroundImageLight.url ?? undefined : undefined,
  backgroundImageDark: typeof backgroundImageDark === "object" && backgroundImageDark !== null ? backgroundImageDark.url ?? undefined : undefined,
};
---
<Component {...remappedProps} />
