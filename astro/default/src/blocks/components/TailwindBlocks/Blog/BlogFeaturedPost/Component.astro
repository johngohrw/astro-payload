---
export interface FeaturedPost {
  date: string;
  dateTime: string;
  title: string;
  excerpt: string;
  readMoreHref: string;
  authorName: string;
  authorHref: string;
  authorImageSrc: string;
  authorImageAlt?: string;
}

export interface PostItem {
  date: string;
  dateTime: string;
  title: string;
  titleHref: string;
  excerpt: string;
  authorName: string;
  authorHref: string;
  authorImageSrc: string;
  authorImageAlt?: string;
}

export interface Props {
  featuredPost?: FeaturedPost;
  posts?: PostItem[];
}

const {
  featuredPost = {
    date: "Mar 16, 2020",
    dateTime: "2020-03-16",
    title: "We're incredibly proud to announce we have secured $75m in Series B",
    excerpt:
      "Libero neque aenean tincidunt nec consequat tempor. Viverra odio id velit adipiscing id. Nisi vestibulum orci eget bibendum dictum. Velit viverra posuere vulputate volutpat nunc. Nunc netus sit faucibus.",
    readMoreHref: "#",
    authorName: "Michael Foster",
    authorHref: "#",
    authorImageSrc: "https://picsum.photos/300",
    authorImageAlt: "",
  },
  posts = [
    {
      date: "Mar 10, 2020",
      dateTime: "2020-03-16",
      title: "Boost your conversion rate",
      titleHref: "#",
      excerpt:
        "Illo sint voluptas. Error voluptates culpa eligendi. Hic vel totam vitae illo. Non aliquid explicabo necessitatibus unde. Sed exercitationem placeat consectetur nulla deserunt vel iusto corrupti dicta laboris incididunt.",
      authorName: "Lindsay Walton",
      authorHref: "#",
      authorImageSrc: "https://picsum.photos/300",
      authorImageAlt: "",
    },
    {
      date: "Feb 12, 2020",
      dateTime: "2020-03-10",
      title: "How to use search engine optimization to drive sales",
      titleHref: "#",
      excerpt:
        "Optio sit exercitation et ex ullamco aliquid explicabo. Dolore do ut officia anim non ad eu. Magna laboris incididunt commodo elit ipsum.",
      authorName: "Tom Cook",
      authorHref: "#",
      authorImageSrc: "https://picsum.photos/300",
      authorImageAlt: "",
    },
  ],
} = Astro.props;
---

<div class="bg-white py-24 sm:py-32 dark:bg-gray-900">
  <div class="mx-auto grid max-w-7xl grid-cols-1 gap-x-8 gap-y-12 px-6 sm:gap-y-16 lg:grid-cols-2 lg:px-8">
    <article class="mx-auto w-full max-w-2xl lg:mx-0 lg:max-w-lg">
      <time datetime={featuredPost.dateTime} class="block text-sm/6 text-gray-600 dark:text-gray-400">{featuredPost.date}</time>
      <h2 id="featured-post" class="mt-4 text-3xl font-semibold tracking-tight text-pretty text-gray-900 sm:text-4xl dark:text-white">{featuredPost.title}</h2>
      <p class="mt-4 text-lg/8 text-gray-600 dark:text-gray-400">{featuredPost.excerpt}</p>
      <div class="mt-4 flex flex-col justify-between gap-6 sm:mt-8 sm:flex-row-reverse sm:gap-8 lg:mt-4 lg:flex-col">
        <div class="flex">
          <a href={featuredPost.readMoreHref} aria-describedby="featured-post" class="text-sm/6 font-semibold text-indigo-600 hover:text-indigo-500 dark:text-indigo-400 dark:hover:text-indigo-300">Continue reading <span aria-hidden="true">&rarr;</span></a>
        </div>
        <div class="flex lg:border-t lg:border-gray-900/10 lg:pt-8 dark:lg:border-white/10">
          <a href={featuredPost.authorHref} class="flex gap-x-2.5 text-sm/6 font-semibold text-gray-900 dark:text-white">
            <img src={featuredPost.authorImageSrc} alt={featuredPost.authorImageAlt ?? ""} class="size-6 flex-none rounded-full bg-gray-50 dark:bg-gray-800" />
            {featuredPost.authorName}
          </a>
        </div>
      </div>
    </article>
    <div class="mx-auto w-full max-w-2xl border-t border-gray-900/10 pt-12 sm:pt-16 lg:mx-0 lg:max-w-none lg:border-t-0 lg:pt-0 dark:border-white/10">
      <div class="-my-12 divide-y divide-gray-900/10 dark:divide-white/10">
        {posts.map((post) => (
          <article class="py-12">
            <div class="group relative max-w-xl">
              <time datetime={post.dateTime} class="block text-sm/6 text-gray-600 dark:text-gray-400">{post.date}</time>
              <h2 class="mt-2 text-lg font-semibold text-gray-900 group-hover:text-gray-600 dark:text-white dark:group-hover:text-gray-300">
                <a href={post.titleHref}>
                  <span class="absolute inset-0"></span>
                  {post.title}
                </a>
              </h2>
              <p class="mt-4 text-sm/6 text-gray-600 dark:text-gray-400">{post.excerpt}</p>
            </div>
            <div class="mt-4 flex">
              <a href={post.authorHref} class="relative flex gap-x-2.5 text-sm/6 font-semibold text-gray-900 dark:text-white">
                <img src={post.authorImageSrc} alt={post.authorImageAlt ?? ""} class="size-6 flex-none rounded-full bg-gray-50 dark:bg-gray-800" />
                {post.authorName}
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</div>
