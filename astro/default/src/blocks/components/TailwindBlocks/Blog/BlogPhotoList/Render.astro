---
import type { BlockTypeOf } from "@/blocks/blockTypes";
import Component from "./Component.astro";

const { block } = Astro.props;

const blockProps: BlockTypeOf<"blogPhotoList"> = block;

const { heading, description, image, openings, viewAllHref, viewAllLabel } = blockProps;

const remappedProps = {
  heading: heading ?? undefined,
  description: description ?? undefined,
  imageSrc:
    typeof image === "object" && image !== null ? image.url ?? undefined : undefined,
  imageAlt:
    typeof image === "object" && image !== null ? image.alt ?? undefined : undefined,
  openings: openings?.map((opening) => ({
    title: opening.title ?? undefined,
    titleHref: opening.titleHref ?? undefined,
    description: opening.description ?? undefined,
    salary: opening.salary ?? undefined,
    location: opening.location ?? undefined,
  })),
  viewAllHref: viewAllHref ?? undefined,
  viewAllLabel: viewAllLabel ?? undefined,
};
---

<Component {...remappedProps} />
