---
export interface FeatureItem {
  title: string;
  description: string;
  iconSvg: string;
}

export interface Props {
  eyebrow?: string;
  heading?: string;
  description?: string;
  features?: FeatureItem[];
}

const CHECK_ICON = `<svg viewBox="0 0 20 20" fill="currentColor" data-slot="icon" aria-hidden="true" class="absolute top-1 left-0 size-5 text-indigo-500 dark:text-indigo-400"><path d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" fill-rule="evenodd" /></svg>`;

const {
  eyebrow = "Everything you need",
  heading = "All-in-one platform",
  description = "Lorem ipsum, dolor sit amet consectetur adipisicing elit. Maiores impedit perferendis suscipit eaque, iste dolor cupiditate blanditiis ratione.",
  features = [
    { title: "Invite team members", description: "Rerum repellat labore necessitatibus reprehenderit molestiae praesentium.", iconSvg: CHECK_ICON },
    { title: "List view", description: "Corporis asperiores ea nulla temporibus asperiores non tempore assumenda aut.", iconSvg: CHECK_ICON },
    { title: "Keyboard shortcuts", description: "In sit qui aliquid deleniti et. Ad nobis sunt omnis. Quo sapiente dicta laboriosam.", iconSvg: CHECK_ICON },
    { title: "Calendars", description: "Sed rerum sunt dignissimos ullam. Iusto iure occaecati voluptate eligendi.", iconSvg: CHECK_ICON },
    { title: "Notifications", description: "Quos inventore harum enim nesciunt. Aut repellat rerum omnis adipisci.", iconSvg: CHECK_ICON },
    { title: "Boards", description: "Quae sit sunt excepturi fugit veniam voluptatem ipsum commodi.", iconSvg: CHECK_ICON },
    { title: "Reporting", description: "Eos laudantium repellat sed architecto earum unde incidunt.", iconSvg: CHECK_ICON },
    { title: "Mobile app", description: "Nulla est saepe accusamus nostrum est est fugit omnis.", iconSvg: CHECK_ICON },
  ],
} = Astro.props;
---

<div class="bg-white py-24 sm:py-32 dark:bg-gray-900">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 sm:gap-y-20 lg:mx-0 lg:max-w-none lg:grid-cols-5">
      <div class="col-span-2">
        <h2 class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">{eyebrow}</h2>
        <p class="mt-2 text-4xl font-semibold tracking-tight text-pretty text-gray-900 sm:text-5xl dark:text-white">{heading}</p>
        <p class="mt-6 text-base/7 text-gray-700 dark:text-gray-300">{description}</p>
      </div>
      <dl class="col-span-3 grid grid-cols-1 gap-x-8 gap-y-10 text-base/7 text-gray-600 sm:grid-cols-2 lg:gap-y-16 dark:text-gray-400">
        {features.map((item) => (
          <div class="relative pl-9">
            <dt class="font-semibold text-gray-900 dark:text-white">
              <Fragment set:html={item.iconSvg} />
              {item.title}
            </dt>
            <dd class="mt-2">{item.description}</dd>
          </div>
        ))}
      </dl>
    </div>
  </div>
</div>
