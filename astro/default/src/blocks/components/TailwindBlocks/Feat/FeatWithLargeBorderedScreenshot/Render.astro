---
import type { BlockTypeOf } from "@/blocks/blockTypes";
import Component from "./Component.astro";
const { block } = Astro.props;
const blockProps: BlockTypeOf<"featWithLargeBorderedScreenshot"> = block;
const { heading, screenshot } = blockProps;
const remappedProps = {
  heading: heading ?? undefined,
  screenshotSrc: typeof screenshot === "object" && screenshot !== null ? screenshot.url ?? undefined : undefined,
  screenshotAlt: typeof screenshot === "object" && screenshot !== null ? screenshot.alt ?? undefined : undefined,
};
---
<Component {...remappedProps} />
