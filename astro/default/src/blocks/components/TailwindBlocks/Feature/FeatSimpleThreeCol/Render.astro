---
import type { BlockTypeOf } from "@/blocks/blockTypes";
import Component from "./Component.astro";

const { block: incomingBlock } = Astro.props;

const block: BlockTypeOf<"featSimpleThreeCol"> = incomingBlock;

const columns =
  block?.columns?.map((col) => ({
    title: col.title ?? "",
    caption: col.caption ?? "",
    icon: col.icon ?? "",
    actionLabel: col.action?.label ?? "",
    actionHref: col.action?.href ?? "",
  })) ?? undefined;
---

<Component
  topCaption={block?.topCaption ?? undefined}
  title={block?.title ?? undefined}
  subtitle={block?.subtitle ?? undefined}
  columns={columns}
/>
