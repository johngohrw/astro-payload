---
import type { BlockTypeOf } from "@/blocks/blockTypes";
import Component from "./Component.astro";

const { block } = Astro.props;

const blockProps: BlockTypeOf<"headingWithStats"> = block;

const { backgroundImage, title, description, links, stats } = blockProps;

const defaultLightBg =
  "https://images.unsplash.com/photo-1521737604893-d14cc237f11d?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&crop=focalpoint&fp-y=.8&w=2830&h=1500&q=80&blend=111827&sat=-100&exp=15&blend-mode=screen";
const defaultDarkBg =
  "https://images.unsplash.com/photo-1521737604893-d14cc237f11d?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&crop=focalpoint&fp-y=.8&w=2830&h=1500&q=80&blend=111827&sat=-100&exp=15&blend-mode=multiply";

const remappedProps = {
  lightBgImage: backgroundImage?.light
    ? typeof backgroundImage.light === "string"
      ? backgroundImage.light
      : ((backgroundImage.light as any)?.url ?? defaultLightBg)
    : defaultLightBg,
  darkBgImage: backgroundImage?.dark
    ? typeof backgroundImage.dark === "string"
      ? backgroundImage.dark
      : ((backgroundImage.dark as any)?.url ?? defaultDarkBg)
    : defaultDarkBg,
  title: title ?? undefined,
  description: description ?? undefined,
  links: links?.map((link) => ({
    label: link.label,
    href: link.href,
  })),
  stats: stats?.map((stat) => ({
    label: stat.label,
    value: stat.value,
  })),
};
---

<Component {...remappedProps} />
