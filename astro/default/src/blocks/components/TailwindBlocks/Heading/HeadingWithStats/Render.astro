---
import type { BlockTypeOf } from "@/blocks/blockTypes";
import Component from "./Component.astro";

const { block } = Astro.props;
const blockProps: BlockTypeOf<"headingWithStats"> = block;
const { lightBgImage, darkBgImage, title, description, links, stats } = blockProps;
const remappedProps = {
  lightBgImage: typeof lightBgImage === "object" && lightBgImage !== null ? lightBgImage.url ?? undefined : undefined,
  darkBgImage: typeof darkBgImage === "object" && darkBgImage !== null ? darkBgImage.url ?? undefined : undefined,
  title: title ?? undefined,
  description: description ?? undefined,
  links: links?.map((link) => ({
    label: link.label ?? undefined,
    href: link.href ?? undefined,
  })),
  stats: stats?.map((stat) => ({
    label: stat.label ?? undefined,
    value: stat.value ?? undefined,
  })),
};
---
<Component {...remappedProps} />
