---
export interface TestimonialItem {
  logoSrc?: string;
  logoAlt?: string;
  quote: string;
  authorImageSrc?: string;
  authorName: string;
  authorTitle: string;
}

export interface Props {
  testimonials?: TestimonialItem[];
}

const {
  testimonials = [
    {
      logoSrc: "https://picsum.photos/300",
      logoAlt: "",
      quote: "Amet amet eget scelerisque tellus sit neque faucibus non eleifend. Integer eu praesent at a. Ornare arcu gravida natoque erat et cursus tortor consequat at. Vulputate gravida sociis enim nullam ultricies habitant malesuada lorem ac. Tincidunt urna dui pellentesque sagittis.",
      authorImageSrc: "https://picsum.photos/300",
      authorName: "Judith Black",
      authorTitle: "CEO of Tuple",
    },
    {
      logoSrc: "https://picsum.photos/300",
      logoAlt: "",
      quote: "Excepteur veniam labore ullamco eiusmod. Pariatur consequat proident duis dolore nulla veniam reprehenderit nisi officia voluptate incididunt exercitation exercitation elit. Nostrud veniam sint dolor nisi ullamco.",
      authorImageSrc: "https://picsum.photos/300",
      authorName: "Joseph Rodriguez",
      authorTitle: "CEO of Reform",
    },
  ],
} = Astro.props;

const [first, second] = testimonials;
---

<section class="bg-white py-24 sm:py-32 dark:bg-gray-900">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto grid max-w-2xl grid-cols-1 lg:mx-0 lg:max-w-none lg:grid-cols-2">
      {first && (
        <div class="flex flex-col pb-10 sm:pb-16 lg:pr-8 lg:pb-0 xl:pr-20">
          <img src={first.logoSrc} alt={first.logoAlt ?? ""} class="h-12 self-start dark:hidden" />
          <img src={first.logoSrc} alt={first.logoAlt ?? ""} class="h-12 self-start not-dark:hidden" />
          <figure class="mt-10 flex flex-auto flex-col justify-between">
            <blockquote class="text-lg/8 text-gray-900 dark:text-gray-100">
              <p>"{first.quote}"</p>
            </blockquote>
            <figcaption class="mt-10 flex items-center gap-x-6">
              <img src={first.authorImageSrc} alt="" class="size-14 rounded-full bg-gray-50 dark:bg-gray-800" />
              <div class="text-base">
                <div class="font-semibold text-gray-900 dark:text-white">{first.authorName}</div>
                <div class="mt-1 text-gray-500 dark:text-gray-400">{first.authorTitle}</div>
              </div>
            </figcaption>
          </figure>
        </div>
      )}
      {second && (
        <div class="flex flex-col border-t border-gray-900/10 pt-10 sm:pt-16 lg:border-t-0 lg:border-l lg:pt-0 lg:pl-8 xl:pl-20 dark:border-white/10">
          <img src={second.logoSrc} alt={second.logoAlt ?? ""} class="h-12 self-start dark:hidden" />
          <img src={second.logoSrc} alt={second.logoAlt ?? ""} class="h-12 self-start not-dark:hidden" />
          <figure class="mt-10 flex flex-auto flex-col justify-between">
            <blockquote class="text-lg/8 text-gray-900 dark:text-gray-100">
              <p>"{second.quote}"</p>
            </blockquote>
            <figcaption class="mt-10 flex items-center gap-x-6">
              <img src={second.authorImageSrc} alt="" class="size-14 rounded-full bg-gray-50 dark:bg-gray-800" />
              <div class="text-base">
                <div class="font-semibold text-gray-900 dark:text-white">{second.authorName}</div>
                <div class="mt-1 text-gray-500 dark:text-gray-400">{second.authorTitle}</div>
              </div>
            </figcaption>
          </figure>
        </div>
      )}
    </div>
  </div>
</section>
