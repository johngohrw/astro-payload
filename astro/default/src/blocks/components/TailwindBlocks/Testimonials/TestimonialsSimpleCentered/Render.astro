---
import type { BlockTypeOf } from "@/blocks/blockTypes";
import Component from "./Component.astro";

const { block } = Astro.props;

const blockProps: BlockTypeOf<"testimonialsSimpleCentered"> = block;

const { logo, quote, authorImage, authorName, authorTitle } = blockProps;

const remappedProps = {
  logoSrc: typeof logo === "object" && logo !== null ? logo.url ?? undefined : undefined,
  logoAlt: typeof logo === "object" && logo !== null ? logo.alt ?? undefined : undefined,
  quote: quote ?? undefined,
  authorImageSrc: typeof authorImage === "object" && authorImage !== null ? authorImage.url ?? undefined : undefined,
  authorName: authorName ?? undefined,
  authorTitle: authorTitle ?? undefined,
};
---

<Component {...remappedProps} />
