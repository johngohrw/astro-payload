---
export interface Testimonial {
  quote: string;
  authorImageSrc?: string;
  authorName: string;
  authorHandle: string;
}

export interface FeaturedTestimonial {
  quote: string;
  authorImageSrc?: string;
  authorName: string;
  authorHandle: string;
  logoSrc?: string;
  logoAlt?: string;
}

export interface Props {
  eyebrow?: string;
  heading?: string;
  featuredTestimonial?: FeaturedTestimonial;
  testimonials?: Testimonial[][];
}

const {
  eyebrow = "Testimonials",
  heading = "We have worked with thousands of amazing people",
  featuredTestimonial = {
    quote: "Integer id nunc sit semper purus. Bibendum at lacus ut arcu blandit montes vitae auctor libero. Hac condimentum dignissim nibh vulputate ut nunc. Amet nibh orci mi venenatis blandit vel et proin. Non hendrerit in vel ac diam.",
    authorImageSrc: "https://picsum.photos/300",
    authorName: "Brenna Goyette",
    authorHandle: "@brennagoyette",
    logoSrc: "https://picsum.photos/300",
    logoAlt: "",
  },
  testimonials = [
    [
      [
        { quote: "Laborum quis quam. Dolorum et ut quod quia. Voluptas numquam delectus nihil. Aut enim doloremque et ipsam.", authorImageSrc: "https://picsum.photos/300", authorName: "Leslie Alexander", authorHandle: "@lesliealexander" },
        { quote: "Quia dolorem qui et. Atque quo aliquid sit eos officia. Dolores similique laboriosam quaerat cupiditate.", authorImageSrc: "https://picsum.photos/300", authorName: "Michael Foster", authorHandle: "@michaelfoster" },
        { quote: "Consequatur ut atque. Itaque nostrum molestiae id veniam eos cumque. Ut quia eum fugit laborum autem inventore ut voluptate.", authorImageSrc: "https://picsum.photos/300", authorName: "Dries Vincent", authorHandle: "@driesvincent" },
      ],
      [
        { quote: "Aut reprehenderit voluptatem eum asperiores beatae id. Iure molestiae ipsam ut officia rem nulla blanditiis.", authorImageSrc: "https://picsum.photos/300", authorName: "Lindsay Walton", authorHandle: "@lindsaywalton" },
        { quote: "Nam nesciunt dolorem dolor asperiores cum. Incidunt molestiae quis deleniti vitae ut in earum delectus iusto.", authorImageSrc: "https://picsum.photos/300", authorName: "Courtney Henry", authorHandle: "@courtneyhenry" },
      ],
    ],
    [
      [
        { quote: "Voluptas quos itaque ipsam in voluptatem est. Iste eos blanditiis repudiandae. Earum deserunt enim molestiae ipsum perferendis recusandae saepe corrupti.", authorImageSrc: "https://picsum.photos/300", authorName: "Tom Cook", authorHandle: "@tomcook" },
        { quote: "Aliquid dolore praesentium ratione. Cumque ea officia repellendus laboriosam. Vitae quod id explicabo non sunt.", authorImageSrc: "https://picsum.photos/300", authorName: "Whitney Francis", authorHandle: "@whitneyfrancis" },
      ],
      [
        { quote: "Molestias ea earum quos nostrum doloremque sed. Quaerat quasi aut velit incidunt excepturi rerum voluptatem minus harum.", authorImageSrc: "https://picsum.photos/300", authorName: "Leonard Krasner", authorHandle: "@leonardkrasner" },
        { quote: "Architecto libero natus est. Est quam debitis officia enim atque et ut non. Sunt reiciendis quasi eaque. Itaque error ut et.", authorImageSrc: "https://picsum.photos/300", authorName: "Floyd Miles", authorHandle: "@floydmiles" },
        { quote: "Temporibus ea molestiae impedit adipisci perspiciatis illo aliquid. Quis ut ratione et voluptatem et. Nostrum explicabo iste unde beatae.", authorImageSrc: "https://picsum.photos/300", authorName: "Emily Selman", authorHandle: "@emilyselman" },
      ],
    ],
  ],
} = Astro.props;
---

<div class="relative isolate bg-white pt-24 pb-32 sm:pt-32 dark:bg-gray-900">
  <div aria-hidden="true" class="absolute inset-x-0 top-1/2 -z-10 -translate-y-1/2 transform-gpu overflow-hidden opacity-30 blur-3xl">
    <div style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)" class="ml-[max(50%,38rem)] aspect-1313/771 w-328.25 bg-linear-to-tr from-[#ff80b5] to-[#9089fc]"></div>
  </div>
  <div aria-hidden="true" class="absolute inset-x-0 top-0 -z-10 flex transform-gpu overflow-hidden pt-32 opacity-25 blur-3xl sm:pt-40 xl:justify-end">
    <div style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)" class="-ml-88 aspect-1313/771 w-328.25 flex-none origin-top-right rotate-30 bg-linear-to-tr from-[#ff80b5] to-[#9089fc] xl:mr-[calc(50%-12rem)] xl:ml-0"></div>
  </div>
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">{eyebrow}</h2>
      <p class="mt-2 text-4xl font-semibold tracking-tight text-balance text-gray-900 sm:text-5xl dark:text-white">{heading}</p>
    </div>
    <div class="mx-auto mt-16 grid max-w-2xl grid-cols-1 grid-rows-1 gap-8 text-sm/6 text-gray-900 sm:mt-20 sm:grid-cols-2 xl:mx-0 xl:max-w-none xl:grid-flow-col xl:grid-cols-4 dark:text-gray-100">
      <figure class="rounded-2xl bg-white shadow-lg ring-1 ring-gray-900/5 sm:col-span-2 xl:col-start-2 xl:row-end-1 dark:bg-gray-800/75 dark:shadow-none dark:ring-white/10">
        <blockquote class="p-6 text-lg font-semibold tracking-tight text-gray-900 sm:p-12 sm:text-xl/8 dark:text-white">
          <p>"{featuredTestimonial.quote}"</p>
        </blockquote>
        <figcaption class="flex flex-wrap items-center gap-x-4 gap-y-4 border-t border-gray-900/10 px-6 py-4 sm:flex-nowrap dark:border-white/10">
          <img src={featuredTestimonial.authorImageSrc} alt="" class="size-10 flex-none rounded-full bg-gray-50 dark:bg-gray-700" />
          <div class="flex-auto">
            <div class="font-semibold text-gray-900 dark:text-white">{featuredTestimonial.authorName}</div>
            <div class="text-gray-600 dark:text-gray-400">{featuredTestimonial.authorHandle}</div>
          </div>
          <img src={featuredTestimonial.logoSrc} alt={featuredTestimonial.logoAlt ?? ""} class="h-10 w-auto flex-none dark:hidden" />
          <img src={featuredTestimonial.logoSrc} alt={featuredTestimonial.logoAlt ?? ""} class="h-10 w-auto flex-none not-dark:hidden" />
        </figcaption>
      </figure>
      {testimonials.map((column) => (
        <div class="space-y-8 xl:contents xl:space-y-0">
          {column.map((group, gi) => (
            <div class={`space-y-8 ${gi === 0 ? "xl:row-span-2" : "xl:row-start-1"}`}>
              {group.map((t) => (
                <figure class="rounded-2xl bg-white p-6 shadow-lg ring-1 ring-gray-900/5 dark:bg-gray-800/75 dark:shadow-none dark:ring-white/10">
                  <blockquote class="text-gray-900 dark:text-white">
                    <p>"{t.quote}"</p>
                  </blockquote>
                  <figcaption class="mt-6 flex items-center gap-x-4">
                    <img src={t.authorImageSrc} alt="" class="size-10 rounded-full bg-gray-50 dark:bg-gray-700" />
                    <div>
                      <div class="font-semibold text-gray-900 dark:text-white">{t.authorName}</div>
                      <div class="text-gray-600 dark:text-gray-400">{t.authorHandle}</div>
                    </div>
                  </figcaption>
                </figure>
              ))}
            </div>
          ))}
        </div>
      ))}
    </div>
  </div>
</div>
