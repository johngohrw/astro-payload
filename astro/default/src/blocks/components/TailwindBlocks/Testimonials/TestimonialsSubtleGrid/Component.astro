---
export interface Testimonial {
  quote: string;
  authorImageSrc?: string;
  authorName: string;
  authorHandle: string;
}

export interface Props {
  eyebrow?: string;
  heading?: string;
  testimonials?: Testimonial[];
}

const {
  eyebrow = "Testimonials",
  heading = "We have worked with thousands of amazing people",
  testimonials = [
    { quote: "Laborum quis quam. Dolorum et ut quod quia. Voluptas numquam delectus nihil. Aut enim doloremque et ipsam.", authorImageSrc: "https://picsum.photos/300", authorName: "Leslie Alexander", authorHandle: "@lesliealexander" },
    { quote: "Anim sit consequat culpa commodo eu do nisi commodo ut aute aliqua. Laborum esse duis tempor consectetur officia mollit fugiat. Exercitation qui elit minim minim quis fugiat ex.", authorImageSrc: "https://picsum.photos/300", authorName: "Michael Foster", authorHandle: "@michaelfoster" },
    { quote: "Consequatur ut atque. Itaque nostrum molestiae id veniam eos cumque.", authorImageSrc: "https://picsum.photos/300", authorName: "Dries Vincent", authorHandle: "@driesvincent" },
    { quote: "Excepteur consectetur deserunt id incididunt veniam mollit officia sint qui aute duis sit cillum. Reprehenderit fugiat amet aliqua in commodo minim sunt laborum.", authorImageSrc: "https://picsum.photos/300", authorName: "Lindsay Walton", authorHandle: "@lindsaywalton" },
    { quote: "Distinctio facere aliquam est qui atque sint molestias ad. Fuga consequuntur asperiores voluptatum ipsum.", authorImageSrc: "https://picsum.photos/300", authorName: "Courtney Henry", authorHandle: "@courtneyhenry" },
    { quote: "Nam nesciunt dolorem dolor asperiores sint. Incidunt molestiae quis deleniti vitae ut in earum delectus iusto.", authorImageSrc: "https://picsum.photos/300", authorName: "Tom Cook", authorHandle: "@tomcook" },
    { quote: "Voluptas quos itaque ipsam in voluptatem est. Iste eos blanditiis repudiandae. Earum deserunt enim molestiae ipsum perferendis.", authorImageSrc: "https://picsum.photos/300", authorName: "Whitney Francis", authorHandle: "@whitneyfrancis" },
    { quote: "Aliquid dolore praesentium ratione. Cumque ea officia repellendus laboriosam. Vitae quod id explicabo non sunt.", authorImageSrc: "https://picsum.photos/300", authorName: "Leonard Krasner", authorHandle: "@leonardkrasner" },
    { quote: "Molestias ea earum quos nostrum doloremque sed. Quaerat quasi aut velit incidunt excepturi rerum voluptatem minus harum.", authorImageSrc: "https://picsum.photos/300", authorName: "Floyd Miles", authorHandle: "@floydmiles" },
  ],
} = Astro.props;
---

<div class="bg-white py-24 sm:py-32 dark:bg-gray-900">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">{eyebrow}</h2>
      <p class="mt-2 text-4xl font-semibold tracking-tight text-balance text-gray-900 sm:text-5xl dark:text-white">{heading}</p>
    </div>
    <div class="mx-auto mt-16 flow-root max-w-2xl sm:mt-20 lg:mx-0 lg:max-w-none">
      <div class="-mt-8 sm:-mx-4 sm:columns-2 sm:text-[0] lg:columns-3">
        {testimonials.map((t) => (
          <div class="pt-8 sm:inline-block sm:w-full sm:px-4">
            <figure class="rounded-2xl bg-gray-50 p-8 text-sm/6 dark:bg-white/2.5">
              <blockquote class="text-gray-900 dark:text-gray-100">
                <p>"{t.quote}"</p>
              </blockquote>
              <figcaption class="mt-6 flex items-center gap-x-4">
                <img src={t.authorImageSrc} alt="" class="size-10 rounded-full bg-gray-50 dark:bg-gray-800" />
                <div>
                  <div class="font-semibold text-gray-900 dark:text-white">{t.authorName}</div>
                  <div class="text-gray-600 dark:text-gray-400">{t.authorHandle}</div>
                </div>
              </figcaption>
            </figure>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>
