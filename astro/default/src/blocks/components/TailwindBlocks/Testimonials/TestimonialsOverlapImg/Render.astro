---
import type { BlockTypeOf } from "@/blocks/blockTypes";
import Component from "./Component.astro";

const { block } = Astro.props;

const blockProps: BlockTypeOf<"testimonialsOverlapImg"> = block;

const { personImage, quote, authorName, authorTitle } = blockProps;

const remappedProps = {
  personImageSrc: typeof personImage === "object" && personImage !== null ? personImage.url ?? undefined : undefined,
  quote: quote ?? undefined,
  authorName: authorName ?? undefined,
  authorTitle: authorTitle ?? undefined,
};
---

<Component {...remappedProps} />
