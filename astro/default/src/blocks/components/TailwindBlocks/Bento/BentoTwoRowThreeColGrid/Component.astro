---
export interface BentoCard {
  eyebrow?: string;
  title?: string;
  description?: string;
  lightImageSrc?: string;
  darkImageSrc?: string;
}

export interface Props {
  sectionEyebrow?: string;
  sectionHeading?: string;
  topCards?: BentoCard[];
  bottomCards?: BentoCard[];
}

const {
  sectionEyebrow = "Deploy faster",
  sectionHeading = "Everything you need to deploy your app",
  topCards = [
    {
      eyebrow: "Performance",
      title: "Lightning-fast builds",
      description: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. In gravida justo et nulla efficitur, maximus egestas sem pellentesque.",
      lightImageSrc: "https://picsum.photos/600/320",
      darkImageSrc: "https://picsum.photos/600/320",
    },
    {
      eyebrow: "Releases",
      title: "Push to deploy",
      description: "Curabitur auctor, ex quis auctor venenatis, eros arcu rhoncus massa, laoreet dapibus ex elit vitae odio.",
      lightImageSrc: "https://picsum.photos/600/320",
      darkImageSrc: "https://picsum.photos/600/320",
    },
  ],
  bottomCards = [
    {
      eyebrow: "Speed",
      title: "Built for power users",
      description: "Sed congue eros non finibus molestie. Vestibulum euismod augue.",
      lightImageSrc: "https://picsum.photos/400/320",
      darkImageSrc: "https://picsum.photos/400/320",
    },
    {
      eyebrow: "Integrations",
      title: "Connect your favorite tools",
      description: "Maecenas at augue sed elit dictum vulputate, in nisi aliquam maximus arcu.",
      lightImageSrc: "https://picsum.photos/400/320",
      darkImageSrc: "https://picsum.photos/400/320",
    },
    {
      eyebrow: "Network",
      title: "Globally distributed CDN",
      description: "Aenean vulputate justo commodo auctor vehicula in malesuada semper.",
      lightImageSrc: "https://picsum.photos/400/320",
      darkImageSrc: "https://picsum.photos/400/320",
    },
  ],
} = Astro.props;
---

<div class="bg-white py-24 sm:py-32 dark:bg-gray-900">
  <div class="mx-auto max-w-2xl px-6 lg:max-w-7xl lg:px-8">
    <h2 class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">{sectionEyebrow}</h2>
    <p class="mt-2 max-w-lg text-4xl font-semibold tracking-tight text-pretty text-gray-950 sm:text-5xl dark:text-white">{sectionHeading}</p>
    <div class="mt-10 grid grid-cols-1 gap-4 sm:mt-16 lg:grid-cols-6 lg:grid-rows-2">
      {topCards[0] && (
        <div class="relative lg:col-span-3">
          <div class="absolute inset-0 rounded-lg bg-white max-lg:rounded-t-4xl lg:rounded-tl-4xl dark:bg-gray-800"></div>
          <div class="relative flex h-full flex-col overflow-hidden rounded-[calc(var(--radius-lg)+1px)] max-lg:rounded-t-[calc(2rem+1px)] lg:rounded-tl-[calc(2rem+1px)]">
            <img src={topCards[0].lightImageSrc} alt="" class="h-80 object-cover object-left dark:hidden" />
            <img src={topCards[0].darkImageSrc} alt="" class="h-80 object-cover object-left not-dark:hidden" />
            <div class="p-10 pt-4">
              <h3 class="text-sm/4 font-semibold text-indigo-600 dark:text-indigo-400">{topCards[0].eyebrow}</h3>
              <p class="mt-2 text-lg font-medium tracking-tight text-gray-950 dark:text-white">{topCards[0].title}</p>
              <p class="mt-2 max-w-lg text-sm/6 text-gray-600 dark:text-gray-400">{topCards[0].description}</p>
            </div>
          </div>
          <div class="pointer-events-none absolute inset-0 rounded-lg shadow-sm outline outline-black/5 max-lg:rounded-t-4xl lg:rounded-tl-4xl dark:outline-white/15"></div>
        </div>
      )}
      {topCards[1] && (
        <div class="relative lg:col-span-3">
          <div class="absolute inset-0 rounded-lg bg-white lg:rounded-tr-4xl dark:bg-gray-800"></div>
          <div class="relative flex h-full flex-col overflow-hidden rounded-[calc(var(--radius-lg)+1px)] lg:rounded-tr-[calc(2rem+1px)]">
            <img src={topCards[1].lightImageSrc} alt="" class="h-80 object-cover object-left lg:object-right dark:hidden" />
            <img src={topCards[1].darkImageSrc} alt="" class="h-80 object-cover object-left not-dark:hidden lg:object-right" />
            <div class="p-10 pt-4">
              <h3 class="text-sm/4 font-semibold text-indigo-600 dark:text-indigo-400">{topCards[1].eyebrow}</h3>
              <p class="mt-2 text-lg font-medium tracking-tight text-gray-950 dark:text-white">{topCards[1].title}</p>
              <p class="mt-2 max-w-lg text-sm/6 text-gray-600 dark:text-gray-400">{topCards[1].description}</p>
            </div>
          </div>
          <div class="pointer-events-none absolute inset-0 rounded-lg shadow-sm outline outline-black/5 lg:rounded-tr-4xl dark:outline-white/15"></div>
        </div>
      )}
      {bottomCards[0] && (
        <div class="relative lg:col-span-2">
          <div class="absolute inset-0 rounded-lg bg-white lg:rounded-bl-4xl dark:bg-gray-800"></div>
          <div class="relative flex h-full flex-col overflow-hidden rounded-[calc(var(--radius-lg)+1px)] lg:rounded-bl-[calc(2rem+1px)]">
            <img src={bottomCards[0].lightImageSrc} alt="" class="h-80 object-cover object-left dark:hidden" />
            <img src={bottomCards[0].darkImageSrc} alt="" class="h-80 object-cover object-left not-dark:hidden" />
            <div class="p-10 pt-4">
              <h3 class="text-sm/4 font-semibold text-indigo-600 dark:text-indigo-400">{bottomCards[0].eyebrow}</h3>
              <p class="mt-2 text-lg font-medium tracking-tight text-gray-950 dark:text-white">{bottomCards[0].title}</p>
              <p class="mt-2 max-w-lg text-sm/6 text-gray-600 dark:text-gray-400">{bottomCards[0].description}</p>
            </div>
          </div>
          <div class="pointer-events-none absolute inset-0 rounded-lg shadow-sm outline outline-black/5 lg:rounded-bl-4xl dark:outline-white/15"></div>
        </div>
      )}
      {bottomCards[1] && (
        <div class="relative lg:col-span-2">
          <div class="absolute inset-0 rounded-lg bg-white dark:bg-gray-800"></div>
          <div class="relative flex h-full flex-col overflow-hidden rounded-[calc(var(--radius-lg)+1px)]">
            <img src={bottomCards[1].lightImageSrc} alt="" class="h-80 object-cover dark:hidden" />
            <img src={bottomCards[1].darkImageSrc} alt="" class="h-80 object-cover not-dark:hidden" />
            <div class="p-10 pt-4">
              <h3 class="text-sm/4 font-semibold text-indigo-600 dark:text-indigo-400">{bottomCards[1].eyebrow}</h3>
              <p class="mt-2 text-lg font-medium tracking-tight text-gray-950 dark:text-white">{bottomCards[1].title}</p>
              <p class="mt-2 max-w-lg text-sm/6 text-gray-600 dark:text-gray-400">{bottomCards[1].description}</p>
            </div>
          </div>
          <div class="pointer-events-none absolute inset-0 rounded-lg shadow-sm outline outline-black/5 dark:outline-white/15"></div>
        </div>
      )}
      {bottomCards[2] && (
        <div class="relative lg:col-span-2">
          <div class="absolute inset-0 rounded-lg bg-white max-lg:rounded-b-4xl lg:rounded-br-4xl dark:bg-gray-800"></div>
          <div class="relative flex h-full flex-col overflow-hidden rounded-[calc(var(--radius-lg)+1px)] max-lg:rounded-b-[calc(2rem+1px)] lg:rounded-br-[calc(2rem+1px)]">
            <img src={bottomCards[2].lightImageSrc} alt="" class="h-80 object-cover dark:hidden" />
            <img src={bottomCards[2].darkImageSrc} alt="" class="h-80 object-cover not-dark:hidden" />
            <div class="p-10 pt-4">
              <h3 class="text-sm/4 font-semibold text-indigo-600 dark:text-indigo-400">{bottomCards[2].eyebrow}</h3>
              <p class="mt-2 text-lg font-medium tracking-tight text-gray-950 dark:text-white">{bottomCards[2].title}</p>
              <p class="mt-2 max-w-lg text-sm/6 text-gray-600 dark:text-gray-400">{bottomCards[2].description}</p>
            </div>
          </div>
          <div class="pointer-events-none absolute inset-0 rounded-lg shadow-sm outline outline-black/5 max-lg:rounded-b-4xl lg:rounded-br-4xl dark:outline-white/15"></div>
        </div>
      )}
    </div>
  </div>
</div>
