---
import type { BlockTypeOf } from "@/blocks/blockTypes";
import Component from "./Component.astro";

const { block } = Astro.props;
const blockProps: BlockTypeOf<"ctaImageTiles"> = block;
const { heading, subheading, description, ctaLabel, ctaHref, images } = blockProps;
const remappedProps = {
  heading: heading ?? undefined,
  subheading: subheading ?? undefined,
  description: description ?? undefined,
  ctaLabel: ctaLabel ?? undefined,
  ctaHref: ctaHref ?? undefined,
  images: images?.map((item) => ({
    src: typeof item.image === "object" && item.image !== null ? item.image.url ?? undefined : undefined,
    alt: item.alt ?? undefined,
  })),
};
---
<Component {...remappedProps} />
