---
export interface Props {
  heading?: string;
  descriptionPrimary?: string;
  descriptionSecondary?: string;
  ctaLabel?: string;
  ctaHref?: string;
  imageLargeSrc?: string;
  imageLargeAlt?: string;
  imageTopLeftSrc?: string;
  imageTopLeftAlt?: string;
  imageMiddleSrc?: string;
  imageMiddleAlt?: string;
  imageBottomRightSrc?: string;
  imageBottomRightAlt?: string;
}

const {
  heading = "Our people",
  descriptionPrimary = "Quasi est quaerat. Sit molestiae et. Provident ad dolorem occaecati eos iste. Soluta rerum quidem minus ut molestiae velit error quod. Excepturi quidem expedita molestias quas.",
  descriptionSecondary = "Anim aute id magna aliqua ad ad non deserunt sunt. Qui irure qui lorem cupidatat commodo. Elit sunt amet fugiat veniam occaecat fugiat. Quasi aperiam sit non sit neque reprehenderit.",
  ctaLabel = "Join our team",
  ctaHref = "#",
  imageLargeSrc = "https://picsum.photos/300",
  imageLargeAlt = "",
  imageTopLeftSrc = "https://picsum.photos/300",
  imageTopLeftAlt = "",
  imageMiddleSrc = "https://picsum.photos/300",
  imageMiddleAlt = "",
  imageBottomRightSrc = "https://picsum.photos/300",
  imageBottomRightAlt = "",
} = Astro.props;
---

<div class="overflow-hidden bg-white py-32 dark:bg-gray-900">
  <div class="mx-auto max-w-7xl px-6 lg:flex lg:px-8">
    <div class="mx-auto grid max-w-2xl grid-cols-1 gap-x-12 gap-y-16 lg:mx-0 lg:max-w-none lg:min-w-full lg:flex-none lg:gap-y-8">
      <div class="lg:col-end-1 lg:w-full lg:max-w-lg lg:pb-8">
        <h2 class="text-4xl font-semibold tracking-tight text-gray-900 sm:text-5xl dark:text-white">{heading}</h2>
        <p class="mt-6 text-xl/8 text-gray-700 dark:text-gray-300">{descriptionPrimary}</p>
        <p class="mt-6 text-base/7 text-gray-600 dark:text-gray-400">{descriptionSecondary}</p>
        <div class="mt-10 flex">
          <a href={ctaHref} class="rounded-md bg-indigo-600 px-3.5 py-2.5 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 dark:bg-indigo-500 dark:hover:bg-indigo-400 dark:focus-visible:outline-indigo-500">
            {ctaLabel}
            <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
      <div class="flex flex-wrap items-start justify-end gap-6 sm:gap-8 lg:contents">
        <div class="w-0 flex-auto lg:ml-auto lg:w-auto lg:flex-none lg:self-end">
          <img src={imageLargeSrc} alt={imageLargeAlt} class="aspect-7/5 w-148 max-w-none rounded-2xl bg-gray-50 object-cover max-sm:w-120 dark:bg-gray-800" />
        </div>
        <div class="contents lg:col-span-2 lg:col-end-2 lg:ml-auto lg:flex lg:w-148 lg:items-start lg:justify-end lg:gap-x-8">
          <div class="order-first flex w-64 flex-none justify-end self-end max-sm:w-40 lg:w-auto">
            <img src={imageTopLeftSrc} alt={imageTopLeftAlt} class="aspect-4/3 w-[24rem] max-w-none flex-none rounded-2xl bg-gray-50 object-cover dark:bg-gray-800" />
          </div>
          <div class="flex w-96 flex-auto justify-end lg:w-auto lg:flex-none">
            <img src={imageMiddleSrc} alt={imageMiddleAlt} class="aspect-7/5 w-148 max-w-none flex-none rounded-2xl bg-gray-50 object-cover max-sm:w-120 dark:bg-gray-800" />
          </div>
          <div class="hidden sm:block sm:w-0 sm:flex-auto lg:w-auto lg:flex-none">
            <img src={imageBottomRightSrc} alt={imageBottomRightAlt} class="aspect-4/3 w-[24rem] max-w-none rounded-2xl bg-gray-50 object-cover dark:bg-gray-800" />
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
