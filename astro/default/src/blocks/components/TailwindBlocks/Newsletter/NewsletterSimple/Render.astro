---
import type { BlockTypeOf } from "@/blocks/blockTypes";
import Component from "./Component.astro";

const { block } = Astro.props;
const blockProps: BlockTypeOf<"newsletterSimple"> = block;
const { heading, emailPlaceholder, subscribeLabel, privacyText, privacyLinkLabel, privacyLinkHref } = blockProps;
const remappedProps = {
  heading: heading ?? undefined,
  emailPlaceholder: emailPlaceholder ?? undefined,
  subscribeLabel: subscribeLabel ?? undefined,
  privacyText: privacyText ?? undefined,
  privacyLinkLabel: privacyLinkLabel ?? undefined,
  privacyLinkHref: privacyLinkHref ?? undefined,
};
---
<Component {...remappedProps} />
