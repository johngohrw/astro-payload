---
import type { BlockTypeOf } from "@/blocks/blockTypes";
import Component from "./Component.astro";

const { block } = Astro.props;

const blockProps: BlockTypeOf<"newsletterSbsOnCard"> = block;

const { heading, emailPlaceholder, submitLabel, privacyText, privacyLabel, privacyHref } = blockProps;

const remappedProps = {
  heading: heading ?? undefined,
  emailPlaceholder: emailPlaceholder ?? undefined,
  submitLabel: submitLabel ?? undefined,
  privacyText: privacyText ?? undefined,
  privacyLabel: privacyLabel ?? undefined,
  privacyHref: privacyHref ?? undefined,
};
---

<Component {...remappedProps} />
