---
export interface SocialLink {
  label: string;
  href: string;
  iconSvg: string;
}

export interface Props {
  socialLinks?: SocialLink[];
  copyrightText?: string;
}

const {
  socialLinks = [],
  copyrightText = "© 2024 Your Company, Inc. All rights reserved.",
} = Astro.props;
---

<footer class="bg-white dark:bg-gray-900">
  <div class="mx-auto max-w-7xl px-6 py-12 md:flex md:items-center md:justify-between lg:px-8">
    <div class="flex justify-center gap-x-6 md:order-2">
      {socialLinks.map((social) => (
        <a href={social.href} class="text-gray-600 hover:text-gray-800 dark:text-gray-400 dark:hover:text-white">
          <span class="sr-only">{social.label}</span>
          <Fragment set:html={social.iconSvg} />
        </a>
      ))}
    </div>
    <p class="mt-8 text-center text-sm/6 text-gray-600 md:order-1 md:mt-0 dark:text-gray-400">{copyrightText}</p>
  </div>
</footer>
