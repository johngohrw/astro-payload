---
import type { BlockTypeOf } from "@/blocks/blockTypes";
import Component from "./Component.astro";

const { block } = Astro.props;

const blockProps: BlockTypeOf<"footer4ColCta"> = block;

const { ctaEyebrow, ctaHeading, ctaDescription, ctaButtonLabel, ctaButtonHref, logoSrc, logoDarkSrc, logoAlt, columns, socialLinks, copyrightText } = blockProps;

const remappedProps = {
  ctaEyebrow: ctaEyebrow ?? undefined,
  ctaHeading: ctaHeading ?? undefined,
  ctaDescription: ctaDescription ?? undefined,
  ctaButtonLabel: ctaButtonLabel ?? undefined,
  ctaButtonHref: ctaButtonHref ?? undefined,
  logoSrc: typeof logoSrc === "object" && logoSrc !== null ? logoSrc.url ?? undefined : undefined,
  logoDarkSrc: typeof logoDarkSrc === "object" && logoDarkSrc !== null ? logoDarkSrc.url ?? undefined : undefined,
  logoAlt: logoAlt ?? undefined,
  columns: columns?.map((col) => ({
    heading: col.heading ?? "",
    links: col.links?.map((link) => ({
      label: link.label ?? "",
      href: link.href ?? "",
    })) ?? [],
  })),
  socialLinks: socialLinks?.map((s) => ({
    label: s.label ?? "",
    href: s.href ?? "",
    iconSvg: s.iconSvg ?? "",
  })),
  copyrightText: copyrightText ?? undefined,
};
---

<Component {...remappedProps} />
