---
import type { BlockTypeOf } from "@/blocks/blockTypes";
import Component from "./Component.astro";

const { block } = Astro.props;

const blockProps: BlockTypeOf<"footerSmCentered"> = block;

const { navLinks, socialLinks, copyrightText } = blockProps;

const remappedProps = {
  navLinks: navLinks?.map((link) => ({
    label: link.label ?? "",
    href: link.href ?? "",
  })),
  socialLinks: socialLinks?.map((s) => ({
    label: s.label ?? "",
    href: s.href ?? "",
    iconSvg: s.iconSvg ?? "",
  })),
  copyrightText: copyrightText ?? undefined,
};
---

<Component {...remappedProps} />
