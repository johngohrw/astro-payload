---
export interface NavLink {
  label: string;
  href: string;
}

export interface SocialLink {
  label: string;
  href: string;
  iconSvg: string;
}

export interface Props {
  navLinks?: NavLink[];
  socialLinks?: SocialLink[];
  copyrightText?: string;
}

const {
  navLinks = [
    { label: "About", href: "#" },
    { label: "Blog", href: "#" },
    { label: "Jobs", href: "#" },
    { label: "Press", href: "#" },
    { label: "Accessibility", href: "#" },
    { label: "Partners", href: "#" },
  ],
  socialLinks = [],
  copyrightText = "© 2024 Your Company, Inc. All rights reserved.",
} = Astro.props;
---

<footer class="bg-white dark:bg-gray-900">
  <div class="mx-auto max-w-7xl overflow-hidden px-6 py-20 sm:py-24 lg:px-8">
    <nav aria-label="Footer" class="-mb-6 flex flex-wrap justify-center gap-x-12 gap-y-3 text-sm/6">
      {navLinks.map((link) => (
        <a href={link.href} class="text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white">{link.label}</a>
      ))}
    </nav>
    <div class="mt-16 flex justify-center gap-x-10">
      {socialLinks.map((social) => (
        <a href={social.href} class="text-gray-600 hover:text-gray-800 dark:text-gray-400 dark:hover:text-white">
          <span class="sr-only">{social.label}</span>
          <Fragment set:html={social.iconSvg} />
        </a>
      ))}
    </div>
    <p class="mt-10 text-center text-sm/6 text-gray-600 dark:text-gray-400">{copyrightText}</p>
  </div>
</footer>
