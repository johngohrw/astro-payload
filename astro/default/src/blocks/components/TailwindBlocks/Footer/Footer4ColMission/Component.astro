---
export interface NavLink {
  label: string;
  href: string;
}

export interface NavColumn {
  heading: string;
  links: NavLink[];
}

export interface SocialLink {
  label: string;
  href: string;
  iconSvg: string;
}

export interface Props {
  logoSrc?: string;
  logoAlt?: string;
  logoDarkSrc?: string;
  missionText?: string;
  socialLinks?: SocialLink[];
  columns?: NavColumn[];
  copyrightText?: string;
}

const {
  logoSrc = "https://picsum.photos/300",
  logoAlt = "Company name",
  logoDarkSrc = "https://picsum.photos/300",
  missionText = "Making the world a better place through constructing elegant hierarchies.",
  socialLinks = [],
  columns = [
    {
      heading: "Solutions",
      links: [
        { label: "Marketing", href: "#" },
        { label: "Analytics", href: "#" },
        { label: "Automation", href: "#" },
        { label: "Commerce", href: "#" },
        { label: "Insights", href: "#" },
      ],
    },
    {
      heading: "Support",
      links: [
        { label: "Submit ticket", href: "#" },
        { label: "Documentation", href: "#" },
        { label: "Guides", href: "#" },
      ],
    },
    {
      heading: "Company",
      links: [
        { label: "About", href: "#" },
        { label: "Blog", href: "#" },
        { label: "Jobs", href: "#" },
        { label: "Press", href: "#" },
      ],
    },
    {
      heading: "Legal",
      links: [
        { label: "Terms of service", href: "#" },
        { label: "Privacy policy", href: "#" },
        { label: "License", href: "#" },
      ],
    },
  ],
  copyrightText = "© 2024 Your Company, Inc. All rights reserved.",
} = Astro.props;
---

<footer class="bg-white dark:bg-gray-900">
  <div class="mx-auto max-w-7xl px-6 pt-16 pb-8 sm:pt-24 lg:px-8 lg:pt-32">
    <div class="xl:grid xl:grid-cols-3 xl:gap-8">
      <div class="space-y-8">
        <img src={logoSrc} alt={logoAlt} class="h-9 dark:hidden" />
        <img src={logoDarkSrc} alt={logoAlt} class="h-9 not-dark:hidden" />
        <p class="text-sm/6 text-balance text-gray-600 dark:text-gray-400">{missionText}</p>
        <div class="flex gap-x-6">
          {socialLinks.map((social) => (
            <a href={social.href} class="text-gray-600 hover:text-gray-800 dark:text-gray-400 dark:hover:text-gray-300">
              <span class="sr-only">{social.label}</span>
              <Fragment set:html={social.iconSvg} />
            </a>
          ))}
        </div>
      </div>
      <div class="mt-16 grid grid-cols-2 gap-8 xl:col-span-2 xl:mt-0">
        <div class="md:grid md:grid-cols-2 md:gap-8">
          {columns.slice(0, 2).map((col, i) => (
            <div class={i === 1 ? "mt-10 md:mt-0" : ""}>
              <h3 class="text-sm/6 font-semibold text-gray-900 dark:text-white">{col.heading}</h3>
              <ul role="list" class="mt-6 space-y-4">
                {col.links.map((link) => (
                  <li>
                    <a href={link.href} class="text-sm/6 text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-300">{link.label}</a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
        <div class="md:grid md:grid-cols-2 md:gap-8">
          {columns.slice(2, 4).map((col, i) => (
            <div class={i === 1 ? "mt-10 md:mt-0" : ""}>
              <h3 class="text-sm/6 font-semibold text-gray-900 dark:text-white">{col.heading}</h3>
              <ul role="list" class="mt-6 space-y-4">
                {col.links.map((link) => (
                  <li>
                    <a href={link.href} class="text-sm/6 text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-300">{link.label}</a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
    <div class="mt-16 border-t border-gray-900/10 pt-8 sm:mt-20 lg:mt-24 dark:border-white/10">
      <p class="text-sm/6 text-gray-600 dark:text-gray-400">{copyrightText}</p>
    </div>
  </div>
</footer>
