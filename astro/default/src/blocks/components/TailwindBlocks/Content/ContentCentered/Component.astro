---
export interface ChecklistItem {
  title: string;
  description: string;
}

export interface Props {
  eyebrow?: string;
  heading?: string;
  intro?: string;
  bodyParagraph1?: string;
  checklistItems?: ChecklistItem[];
  bodyParagraph2?: string;
  subheading1?: string;
  subheading1Body?: string;
  quoteText?: string;
  quoteAuthorName?: string;
  quoteAuthorRole?: string;
  quoteAuthorImageSrc?: string;
  quoteAuthorImageAlt?: string;
  bodyParagraph3?: string;
  mainImageSrc?: string;
  mainImageAlt?: string;
  mainImageCaption?: string;
  subheading2?: string;
  subheading2Body?: string;
  bodyParagraph4?: string;
}

const {
  eyebrow = "Introducing",
  heading = "JavaScript for beginners",
  intro = "Aliquet nec orci mattis amet quisque ullamcorper neque, nibh sem. At arcu, sit dui mi, nibh dui, diam eget aliquam. Quisque id at vitae feugiat egestas ac. Diam nulla orci at in viverra scelerisque eget. Eleifend egestas fringilla sapien.",
