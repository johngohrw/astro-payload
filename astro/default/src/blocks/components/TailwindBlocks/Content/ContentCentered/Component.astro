const checklistSvg = `<path d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z" clip-rule="evenodd" fill-rule="evenodd" />`;
const infoBadgeSvg = `<path d="M18 10a8 8 0 1 1-16 0 8 8 0 0 1 16 0Zm-7-4a1 1 0 1 1-2 0 1 1 0 0 1 2 0ZM9 9a.75.75 0 0 0 0 1.5h.253a.25.25 0 0 1 .244.304l-.459 2.066A1.75 1.75 0 0 0 10.747 15H11a.75.75 0 0 0 0-1.5h-.253a.25.25 0 0 1-.244-.304l.459-2.066A1.75 1.75 0 0 0 9.253 9H9Z" clip-rule="evenodd" fill-rule="evenodd" />`;
---

<div class="bg-white px-6 py-32 lg:px-8 dark:bg-gray-900">
  <div class="mx-auto max-w-3xl text-base/7 text-gray-700 dark:text-gray-300">
    <p class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">{eyebrow}</p>
    <h1 class="mt-2 text-4xl font-semibold tracking-tight text-pretty text-gray-900 sm:text-5xl dark:text-white">{heading}</h1>
    <p class="mt-6 text-xl/8">{intro}</p>
    <div class="mt-10 max-w-2xl text-gray-600 dark:text-gray-400">
      <p>{bodyParagraph1}</p>
      <ul role="list" class="mt-8 max-w-xl space-y-8 text-gray-600 dark:text-gray-400">
        {checklistItems.map((item) => (
          <li class="flex gap-x-3">
            <svg viewBox="0 0 20 20" fill="currentColor" data-slot="icon" aria-hidden="true" class="mt-1 size-5 flex-none text-indigo-600 dark:text-indigo-400">
              <Fragment set:html={checklistSvg} />
            </svg>
            <span><strong class="font-semibold text-gray-900 dark:text-white">{item.title}</strong> {item.description}</span>
          </li>
        ))}
      </ul>
      <p class="mt-8">{bodyParagraph2}</p>
      <h2 class="mt-16 text-3xl font-semibold tracking-tight text-pretty text-gray-900 dark:text-white">{subheading1}</h2>
      <p class="mt-6">{subheading1Body}</p>
      <figure class="mt-10 border-l border-indigo-600 pl-9 dark:border-indigo-400">
        <blockquote class="font-semibold text-gray-900 dark:text-white">
          <p>"{quoteText}"</p>
        </blockquote>
        <figcaption class="mt-6 flex gap-x-4">
          <img src={quoteAuthorImageSrc} alt={quoteAuthorImageAlt} class="size-6 flex-none rounded-full bg-gray-50 dark:bg-gray-800" />
          <div class="text-sm/6"><strong class="font-semibold text-gray-900 dark:text-white">{quoteAuthorName}</strong> – {quoteAuthorRole}</div>
        </figcaption>
      </figure>
      <p class="mt-10">{bodyParagraph3}</p>
    </div>
    <figure class="mt-16">
      <img src={mainImageSrc} alt={mainImageAlt} class="aspect-video rounded-xl bg-gray-50 object-cover dark:bg-gray-800" />
      <figcaption class="mt-4 flex gap-x-2 text-sm/6 text-gray-500 dark:text-gray-400">
        <svg viewBox="0 0 20 20" fill="currentColor" data-slot="icon" aria-hidden="true" class="mt-0.5 size-5 flex-none text-gray-300 dark:text-gray-600">
          <Fragment set:html={infoBadgeSvg} />
        </svg>
        {mainImageCaption}
      </figcaption>
    </figure>
    <div class="mt-16 max-w-2xl text-gray-600 dark:text-gray-400">
      <h2 class="text-3xl font-semibold tracking-tight text-pretty text-gray-900 dark:text-white">{subheading2}</h2>
      <p class="mt-6">{subheading2Body}</p>
      <p class="mt-8">{bodyParagraph4}</p>
    </div>
  </div>
</div>
