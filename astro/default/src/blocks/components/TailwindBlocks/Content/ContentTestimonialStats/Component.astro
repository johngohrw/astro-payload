---
export interface StatItem {
  label: string;
  value: string;
}

export interface Props {
  testimonialImageSrc?: string;
  testimonialImageAlt?: string;
  testimonialLogoSrc?: string;
  testimonialLogoAlt?: string;
  testimonialQuote?: string;
  testimonialAuthorName?: string;
  testimonialAuthorRole?: string;
  eyebrow?: string;
  heading?: string;
  bodyParagraph1?: string;
  bodyParagraph2?: string;
  bodyParagraph3?: string;
  stats?: StatItem[];
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  testimonialImageSrc = "https://picsum.photos/300",
  testimonialImageAlt = "",
  testimonialLogoSrc = "https://picsum.photos/300",
  testimonialLogoAlt = "",
  testimonialQuote = "Amet amet eget scelerisque tellus sit neque faucibus non eleifend. Integer eu praesent at a. Ornare arcu gravida natoque erat et cursus tortor.",
  testimonialAuthorName = "Judith Rogers",
  testimonialAuthorRole = "CEO at Workcation",
  eyebrow = "Company values",
  heading = "On a mission to empower remote teams",
  bodyParagraph1 = "Faucibus commodo massa rhoncus, volutpat. Dignissim sed eget risus enim. Mattis mauris semper sed amet vitae sed turpis id. Id dolor praesent donec est. Odio penatibus risus viverra tellus varius sit neque erat velit. Faucibus commodo massa rhoncus, volutpat. Dignissim sed eget risus enim. Mattis mauris semper sed amet vitae sed turpis id.",
  bodyParagraph2 = "Et vitae blandit facilisi magna lacus commodo. Vitae sapien duis odio id et. Id blandit molestie auctor fermentum dignissim. Lacus diam tincidunt ac cursus in vel. Mauris varius vulputate et ultrices hac adipiscing egestas. Iaculis convallis ac tempor et ut. Ac lorem vel integer orci.",
  bodyParagraph3 = "Et vitae blandit facilisi magna lacus commodo. Vitae sapien duis odio id et. Id blandit molestie auctor fermentum dignissim. Lacus diam tincidunt ac cursus in vel. Mauris varius vulputate et ultrices hac adipiscing egestas. Iaculis convallis ac tempor et ut. Ac lorem vel integer orci.",
  stats = [
    { label: "Founded", value: "2021" },
    { label: "Employees", value: "37" },
    { label: "Countries", value: "12" },
    { label: "Raised", value: "$25M" },
  ],
  ctaLabel = "Learn more about our company",
  ctaHref = "#",
} = Astro.props;
---

<div class="bg-white py-24 sm:py-32 dark:bg-gray-900">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto grid max-w-2xl grid-cols-1 items-start gap-x-8 gap-y-16 sm:gap-y-24 lg:mx-0 lg:max-w-none lg:grid-cols-2">
      <div class="lg:pr-4">
        <div class="relative overflow-hidden rounded-3xl bg-gray-900 px-6 pt-64 pb-9 shadow-2xl sm:px-12 lg:max-w-lg lg:px-8 lg:pb-8 xl:px-10 xl:pb-10 dark:bg-gray-800 dark:shadow-none dark:after:pointer-events-none dark:after:absolute dark:after:inset-0 dark:after:rounded-3xl dark:after:inset-ring dark:after:inset-ring-white/10">
          <img src={testimonialImageSrc} alt={testimonialImageAlt} class="absolute inset-0 size-full rounded-3xl object-cover brightness-125 saturate-0" />
          <div class="absolute inset-0 bg-gray-900 mix-blend-multiply"></div>
          <div aria-hidden="true" class="absolute top-1/2 left-1/2 -ml-16 -translate-x-1/2 -translate-y-1/2 transform-gpu blur-3xl">
            <div style="clip-path: polygon(74.1% 44.1%, 100% 61.6%, 97.5% 26.9%, 85.5% 0.1%, 80.7% 2%, 72.5% 32.5%, 60.2% 62.4%, 52.4% 68.1%, 47.5% 58.3%, 45.2% 34.5%, 27.5% 76.7%, 0.1% 64.9%, 17.9% 100%, 27.6% 76.8%, 76.1% 97.7%, 74.1% 44.1%)" class="aspect-1097/845 w-274.25 bg-linear-to-tr from-[#ff4694] to-[#776fff] opacity-40"></div>
          </div>
          <figure class="relative isolate">
            <img src={testimonialLogoSrc} alt={testimonialLogoAlt} class="h-12 w-auto" />
            <blockquote class="mt-6 text-xl/8 font-semibold text-white">
              <p>"{testimonialQuote}"</p>
            </blockquote>
            <figcaption class="mt-6 text-sm/6 text-gray-300"><strong class="font-semibold text-white">{testimonialAuthorName},</strong> {testimonialAuthorRole}</figcaption>
          </figure>
        </div>
      </div>
      <div>
        <div class="text-base/7 text-gray-700 lg:max-w-lg dark:text-gray-400">
          <p class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400">{eyebrow}</p>
          <h1 class="mt-2 text-4xl font-semibold tracking-tight text-pretty text-gray-900 sm:text-5xl dark:text-white">{heading}</h1>
          <div class="max-w-xl">
            <p class="mt-6">{bodyParagraph1}</p>
            <p class="mt-8">{bodyParagraph2}</p>
            <p class="mt-8">{bodyParagraph3}</p>
          </div>
        </div>
        <dl class="mt-10 grid grid-cols-2 gap-8 border-t border-gray-900/10 pt-10 sm:grid-cols-4 dark:border-gray-800">
          {stats.map((stat) => (
            <div>
              <dt class="text-sm/6 font-semibold text-gray-600 dark:text-gray-400">{stat.label}</dt>
              <dd class="mt-2 text-3xl/10 font-bold tracking-tight text-gray-900 dark:text-white">{stat.value}</dd>
            </div>
          ))}
        </dl>
        <div class="mt-10 flex">
          <a href={ctaHref} class="text-base/7 font-semibold text-indigo-600 hover:text-indigo-500 dark:text-indigo-400 dark:hover:text-indigo-300">{ctaLabel} <span aria-hidden="true">&rarr;</span></a>
        </div>
      </div>
    </div>
  </div>
</div>
