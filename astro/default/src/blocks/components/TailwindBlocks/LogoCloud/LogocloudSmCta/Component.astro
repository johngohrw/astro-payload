---
export interface LogoItem {
  lightSrc?: string;
  darkSrc?: string;
  alt: string;
}

export interface Props {
  logos?: LogoItem[];
  ctaText?: string;
  ctaLinkLabel?: string;
  ctaLinkHref?: string;
}

const {
  logos = [
    { lightSrc: "https://picsum.photos/158/48", darkSrc: "https://picsum.photos/158/48", alt: "Transistor" },
    { lightSrc: "https://picsum.photos/158/48", darkSrc: "https://picsum.photos/158/48", alt: "Reform" },
    { lightSrc: "https://picsum.photos/158/48", darkSrc: "https://picsum.photos/158/48", alt: "Tuple" },
    { lightSrc: "https://picsum.photos/158/48", darkSrc: "https://picsum.photos/158/48", alt: "SavvyCal" },
    { lightSrc: "https://picsum.photos/158/48", darkSrc: "https://picsum.photos/158/48", alt: "Statamic" },
  ],
  ctaText = "Over 2500 companies use our tools to better their business.",
  ctaLinkLabel = "Read our customer stories",
  ctaLinkHref = "#",
} = Astro.props;
---

<div class="bg-white py-24 sm:py-32 dark:bg-gray-900">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto grid max-w-lg grid-cols-4 items-center gap-x-8 gap-y-12 sm:max-w-xl sm:grid-cols-6 sm:gap-x-10 sm:gap-y-14 lg:mx-0 lg:max-w-none lg:grid-cols-5">
      {logos.map((logo) => (
        <>
          {logo.lightSrc && (
            <img width="158" height="48" src={logo.lightSrc} alt={logo.alt} class="col-span-2 max-h-12 w-full object-contain lg:col-span-1 dark:hidden" />
          )}
          {logo.darkSrc && (
            <img width="158" height="48" src={logo.darkSrc} alt={logo.alt} class="col-span-2 max-h-12 w-full object-contain not-dark:hidden lg:col-span-1" />
          )}
        </>
      ))}
    </div>
    <div class="mt-16 flex justify-center">
      <p class="relative rounded-full bg-gray-50 px-4 py-1.5 text-sm/6 text-gray-600 inset-ring inset-ring-gray-900/5 dark:bg-gray-800/75 dark:text-gray-400 dark:inset-ring-white/10">
        <span class="hidden md:inline">{ctaText}</span>
        <a href={ctaLinkHref} class="font-semibold text-indigo-600 hover:text-indigo-500 dark:text-indigo-400 dark:hover:text-indigo-300"><span aria-hidden="true" class="absolute inset-0"></span> {ctaLinkLabel} <span aria-hidden="true">&rarr;</span></a>
      </p>
    </div>
  </div>
</div>
