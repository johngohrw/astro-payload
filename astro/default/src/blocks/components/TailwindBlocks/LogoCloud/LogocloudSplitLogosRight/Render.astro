---
import type { BlockTypeOf } from "@/blocks/blockTypes";
import Component from "./Component.astro";

const { block } = Astro.props;

const blockProps: BlockTypeOf<"logocloudSplitLogosRight"> = block;

const { heading, description, primaryCta, secondaryCta, logos } = blockProps;

const remappedProps = {
  heading: heading ?? undefined,
  description: description ?? undefined,
  primaryCta:
    primaryCta && primaryCta !== null
      ? { label: primaryCta.label ?? "", href: primaryCta.href ?? "#" }
      : undefined,
  secondaryCta:
    secondaryCta && secondaryCta !== null
      ? { label: secondaryCta.label ?? "", href: secondaryCta.href ?? "#" }
      : undefined,
  logos: logos?.map((item) => ({
    lightSrc:
      typeof item.lightSrc === "object" && item.lightSrc !== null
        ? item.lightSrc.url ?? undefined
        : undefined,
    darkSrc:
      typeof item.darkSrc === "object" && item.darkSrc !== null
        ? item.darkSrc.url ?? undefined
        : undefined,
    alt: item.alt ?? "",
  })),
};
---

<Component {...remappedProps} />
