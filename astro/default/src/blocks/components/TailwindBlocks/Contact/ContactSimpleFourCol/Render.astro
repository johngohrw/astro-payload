---
import type { BlockTypeOf } from "@astro-default/blocks/blockTypes";
import Component from "./Component.astro";

const { block } = Astro.props;

const blockProps: BlockTypeOf<"contactSimpleFourCol"> = block;

const { title, subtitle, offices } = blockProps;

const remappedProps = {
  title: title ?? undefined,
  subtitle: subtitle ?? undefined,
  offices: offices?.map((office) => ({
    name: office.name,
    lines: office.lines?.map((item) => item.line) ?? [],
  })),
};
---

<Component {...remappedProps} />
