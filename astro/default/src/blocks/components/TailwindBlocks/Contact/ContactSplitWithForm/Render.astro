---
import type { BlockTypeOf } from "@/blocks/blockTypes";
import Component from "./Component.astro";

const { block } = Astro.props;

const blockProps: BlockTypeOf<"contactSplitWithForm"> = block;

const {
  heading,
  description,
  addressLabel,
  addressHtml,
  phoneLabel,
  phoneText,
  phoneHref,
  emailLabel,
  emailText,
  emailHref,
  formAction,
  submitLabel,
} = blockProps;

const remappedProps = {
  heading: heading ?? undefined,
  description: description ?? undefined,
  addressLabel: addressLabel ?? undefined,
  addressHtml: addressHtml ?? undefined,
  phoneLabel: phoneLabel ?? undefined,
  phoneText: phoneText ?? undefined,
  phoneHref: phoneHref ?? undefined,
  emailLabel: emailLabel ?? undefined,
  emailText: emailText ?? undefined,
  emailHref: emailHref ?? undefined,
  formAction: formAction ?? undefined,
  submitLabel: submitLabel ?? undefined,
};
---

<Component {...remappedProps} />
