---
import type { BlockTypeOf } from "@/blocks/blockTypes";
import Component from "./Component.astro";

const { block } = Astro.props;

const blockProps: BlockTypeOf<"contactSplitPattern"> = block;

const { heading, description, address, phone, email, submitLabel, formAction } = blockProps;

const remappedProps = {
  heading: heading ?? undefined,
  description: description ?? undefined,
  address: address ?? undefined,
  phone: phone ?? undefined,
  email: email ?? undefined,
  submitLabel: submitLabel ?? undefined,
  formAction: formAction ?? undefined,
};
---

<Component {...remappedProps} />
