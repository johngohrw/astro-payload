---
export interface SocialLink {
  label: string;
  href: string;
  iconSvg: string;
}

export interface Member {
  name: string;
  role: string;
  bio: string;
  imageSrc?: string;
  imageAlt?: string;
  socialLinks?: SocialLink[];
}

export interface Props {
  heading?: string;
  description?: string;
  members?: Member[];
}

const xIconSvg = `<path d="M11.4678 8.77491L17.2961 2H15.915L10.8543 7.88256L6.81232 2H2.15039L8.26263 10.8955L2.15039 18H3.53159L8.87581 11.7878L13.1444 18H17.8063L11.4675 8.77491H11.4678ZM9.57608 10.9738L8.95678 10.0881L4.02925 3.03974H6.15068L10.1273 8.72795L10.7466 9.61374L15.9156 17.0075H13.7942L9.57608 10.9742V10.9738Z" />`;
const linkedinIconSvg = `<path d="M16.338 16.338H13.67V12.16c0-.995-.017-2.277-1.387-2.277-1.39 0-1.601 1.086-1.601 2.207v4.248H8.014v-8.59h2.559v1.174h.037c.356-.675 1.227-1.387 2.526-1.387 2.703 0 3.203 1.778 3.203 4.092v4.711zM5.005 6.575a1.548 1.548 0 11-.003-3.096 1.548 1.548 0 01.003 3.096zm-1.337 9.763H6.34v-8.59H3.667v8.59zM17.668 1H2.328C1.595 1 1 1.581 1 2.298v15.403C1 18.418 1.595 19 2.328 19h15.34c.734 0 1.332-.582 1.332-1.299V2.298C19 1.581 18.402 1 17.668 1z" clip-rule="evenodd" fill-rule="evenodd" />`;

const {
  heading = "Meet our leadership",
  description = "We're a dynamic group of individuals who are passionate about what we do and dedicated to delivering the best results for our clients.",
  members = [
    {
      name: "Leonard Krasner",
      role: "Senior Designer",
      bio: "Quia illum aut in beatae. Possimus dolores aliquid accusantium aut in ut non assumenda. Enim iusto molestias aut deleniti eos aliquid magnam molestiae. At et non possimus ab. Magni labore molestiae nulla qui.",
      imageSrc: "https://picsum.photos/300",
      imageAlt: "",
      socialLinks: [
        { label: "X", href: "#", iconSvg: xIconSvg },
        { label: "LinkedIn", href: "#", iconSvg: linkedinIconSvg },
      ],
    },
    {
      name: "Floyd Miles",
      role: "Principal Designer",
      bio: "Turpis lectus et amet elementum. Mi duis integer sed in vitae consequat. Nam vitae, in felis mi dui tempus. Porta at turpis eu odio.",
      imageSrc: "https://picsum.photos/300",
      imageAlt: "",
      socialLinks: [
        { label: "X", href: "#", iconSvg: xIconSvg },
        { label: "LinkedIn", href: "#", iconSvg: linkedinIconSvg },
      ],
    },
  ],
} = Astro.props;
---

<div class="bg-white py-24 sm:py-32 dark:bg-gray-900">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl sm:text-center">
      <h2 class="text-4xl font-semibold tracking-tight text-balance text-gray-900 sm:text-5xl dark:text-white">{heading}</h2>
      <p class="mt-6 text-lg/8 text-gray-600 dark:text-gray-400">{description}</p>
    </div>
    <ul role="list" class="mx-auto mt-20 grid max-w-2xl grid-cols-1 gap-x-6 gap-y-20 sm:grid-cols-2 lg:max-w-4xl lg:gap-x-8 xl:max-w-none">
      {members.map((member) => (
        <li class="flex flex-col gap-6 xl:flex-row">
          <img src={member.imageSrc ?? "https://picsum.photos/300"} alt={member.imageAlt ?? ""} class="aspect-4/5 w-52 flex-none rounded-2xl object-cover outline-1 -outline-offset-1 outline-black/5 dark:outline-white/10" />
          <div class="flex-auto">
            <h3 class="text-lg/8 font-semibold tracking-tight text-gray-900 dark:text-white">{member.name}</h3>
            <p class="text-base/7 text-gray-600 dark:text-gray-400">{member.role}</p>
            <p class="mt-6 text-base/7 text-gray-600 dark:text-gray-400">{member.bio}</p>
            {member.socialLinks && member.socialLinks.length > 0 && (
              <ul role="list" class="mt-6 flex gap-x-6">
                {member.socialLinks.map((link) => (
                  <li>
                    <a href={link.href} class="text-gray-400 hover:text-gray-500 dark:text-gray-400 dark:hover:text-gray-300">
                      <span class="sr-only">{link.label}</span>
                      <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" class="size-5">
                        <Fragment set:html={link.iconSvg} />
                      </svg>
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </div>
        </li>
      ))}
    </ul>
  </div>
</div>
