---
export interface Member {
  name: string;
  role: string;
  location?: string;
  imageSrc?: string;
  imageAlt?: string;
}

export interface Props {
  heading?: string;
  description?: string;
  members?: Member[];
}

const {
  heading = "Our team",
  description = "We're a dynamic group of individuals who are passionate about what we do and dedicated to delivering the best results for our clients.",
  members = [
    { name: "Leslie Alexander", role: "Co-Founder / CEO", location: "Toronto, Canada", imageSrc: "https://picsum.photos/300", imageAlt: "" },
    { name: "Michael Foster", role: "Co-Founder / CTO", location: "Glasgow, Scotland", imageSrc: "https://picsum.photos/300", imageAlt: "" },
    { name: "Dries Vincent", role: "Business Relations", location: "Niagara Falls, Canada", imageSrc: "https://picsum.photos/300", imageAlt: "" },
  ],
} = Astro.props;
---

<div class="bg-white py-24 sm:py-32 dark:bg-gray-900">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl lg:mx-0">
      <h2 class="text-4xl font-semibold tracking-tight text-pretty text-gray-900 sm:text-5xl dark:text-white">{heading}</h2>
      <p class="mt-6 text-lg/8 text-gray-600 dark:text-gray-400">{description}</p>
    </div>
    <ul role="list" class="mx-auto mt-20 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-14 sm:grid-cols-2 lg:mx-0 lg:max-w-none lg:grid-cols-3 xl:grid-cols-4">
      {members.map((member) => (
        <li>
          <img src={member.imageSrc ?? "https://picsum.photos/300"} alt={member.imageAlt ?? ""} class="aspect-14/13 w-full rounded-2xl object-cover outline-1 -outline-offset-1 outline-black/5 dark:outline-white/10" />
          <h3 class="mt-6 text-lg/8 font-semibold tracking-tight text-gray-900 dark:text-white">{member.name}</h3>
          <p class="text-base/7 text-gray-600 dark:text-gray-300">{member.role}</p>
          {member.location && <p class="text-sm/6 text-gray-500">{member.location}</p>}
        </li>
      ))}
    </ul>
  </div>
</div>
