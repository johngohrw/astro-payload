---
export interface StatItem {
  label: string;
  value: string;
}

export interface Props {
  imageSrc?: string;
  imageAlt?: string;
  eyebrow?: string;
  heading?: string;
  description?: string;
  stats?: StatItem[];
}

const {
  imageSrc = "https://images.unsplash.com/photo-1522071820081-009f0129c71c?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=2850&q=80",
  imageAlt = "",
  eyebrow = "Our track record",
  heading = "Trusted by thousands of creators worldwide",
  description = "Lorem ipsum, dolor sit amet consectetur adipisicing elit. Maiores impedit perferendis suscipit eaque, iste dolor cupiditate blanditiis ratione.",
  stats = [
    { label: "Creators on the platform", value: "8,000+" },
    { label: "Flat platform fee", value: "3%" },
    { label: "Uptime guarantee", value: "99.9%" },
    { label: "Paid out to creators", value: "$70M" },
  ],
} = Astro.props;
---

<div class="relative bg-white dark:bg-gray-900">
  <img src={imageSrc} alt={imageAlt} class="h-56 w-full bg-gray-50 object-cover lg:absolute lg:inset-y-0 lg:left-0 lg:h-full lg:w-1/2 dark:bg-gray-800" />
  <div class="mx-auto grid max-w-7xl lg:grid-cols-2">
    <div class="px-6 pt-16 pb-24 sm:pt-20 sm:pb-32 lg:col-start-2 lg:px-8 lg:pt-32">
      <div class="mx-auto max-w-2xl lg:mr-0 lg:max-w-lg">
        <h2 class="text-base/8 font-semibold text-indigo-600 dark:text-indigo-400">{eyebrow}</h2>
        <p class="mt-2 text-4xl font-semibold tracking-tight text-pretty text-gray-900 sm:text-5xl dark:text-white">{heading}</p>
        <p class="mt-6 text-lg/8 text-gray-600 dark:text-gray-300">{description}</p>
        <dl class="mt-16 grid max-w-xl grid-cols-1 gap-8 sm:mt-20 sm:grid-cols-2 xl:mt-16">
          {stats.map((stat) => (
            <div class="flex flex-col gap-y-3 border-l border-gray-900/10 pl-6 dark:border-white/10">
              <dt class="text-sm/6 text-gray-600 dark:text-gray-400">{stat.label}</dt>
              <dd class="order-first text-3xl font-semibold tracking-tight text-gray-900 dark:text-white">{stat.value}</dd>
            </div>
          ))}
        </dl>
      </div>
    </div>
  </div>
</div>
