---
import type { BlockTypeOf } from "@/blocks/blockTypes";
import Component from "./Component.astro";

const { block } = Astro.props;

const blockProps: BlockTypeOf<"statsTimeline"> = block;

const { items } = blockProps;

const remappedProps = {
  items: items?.map((item) => ({
    datetime: item.datetime ?? undefined,
    dateLabel: item.dateLabel ?? undefined,
    title: item.title ?? undefined,
    description: item.description ?? undefined,
  })),
};
---

<Component {...remappedProps} />
