---
import type { BlockTypeOf } from "@/blocks/blockTypes";
import Component from "./Component.astro";

const { block } = Astro.props;

const blockProps: BlockTypeOf<"statsWithDesc"> = block;

const { heading, bodyPrimary, bodySecondary, stats } = blockProps;

const remappedProps = {
  heading: heading ?? undefined,
  bodyPrimary: bodyPrimary ?? undefined,
  bodySecondary: bodySecondary ?? undefined,
  stats: stats?.map((item) => ({
    label: item.label ?? undefined,
    value: item.value ?? undefined,
  })),
};
---

<Component {...remappedProps} />
