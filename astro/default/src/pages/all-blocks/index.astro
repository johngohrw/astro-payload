---
import { allBlocksArray } from "@astro-default/blocks/blockSchemas";
import RenderSingleBlock from "@astro-default/blocks/RenderBlocks/RenderSingleBlock.astro";
import DefaultLayout from "@astro-default/layouts/DefaultLayout.astro";
const allBlocksButEmpty = allBlocksArray.map((o) => {
  return { blockType: o.slug };
});
---

<DefaultLayout>
  {
    allBlocksButEmpty?.map((emptyBlock) => (
      <div>
        <div class="p-3 text-black font-semibold transparent-checker">
          {emptyBlock.blockType}
        </div>
        <div class="relative">
          <RenderSingleBlock block={emptyBlock as any} />
        </div>
      </div>
    ))
  }
</DefaultLayout>
<style>
  .content-wrapper {
    padding: 1rem;
  }
  .transparent-checker {
    background: conic-gradient(
      rgba(0, 0, 0, 0.04) 0 90deg,
      rgba(255, 255, 255, 0.04) 0 180deg,
      rgba(0, 0, 0, 0.04) 0 270deg,
      rgba(255, 255, 255, 0.04) 0
    );
    background-size: 20px 20px;
  }
</style>
