---
// requires iconify's cdn script to be loaded to use
import "iconify-icon";
import type { IconName } from "./icon-names";
import type { ComponentProps, CSSProperty, HTMLAttributes } from "astro/types";
import type { CSSProperties } from "react";

interface Props {
  name: IconName;
  style?: CSSProperties;
  color?: string;
  size?: string;
}

const { name, style, color, size, ...restProps } = Astro.props;
---

<iconify-icon
  icon={name}
  {...restProps}
  style={{ color: color, fontSize: size, ...style }}
>
</iconify-icon>
